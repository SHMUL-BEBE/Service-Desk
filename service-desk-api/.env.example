# ============================================
# БАЗА ДАННЫХ
# ============================================

# Способ 1: Через отдельные переменные
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=service_desk

# Способ 2: Через одну строку подключения (рекомендуется для Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/service_desk

# ============================================
# БЕЗОПАСНОСТЬ
# ============================================

# JWT Secret (обязательно измените!)
JWT_SECRET=your-super-secret-key-change-this-in-production

# ============================================
# НАСТРОЙКИ СЕРВЕРА
# ============================================

# Порт (по умолчанию 3000)
PORT=3000

# Режим работы
NODE_ENV=development

# Разрешённые домены для CORS
CORS_ORIGIN=http://localhost:4200

# ============================================
# ДОПОЛНИТЕЛЬНО
# ============================================

# Время жизни JWT токена (в секундах)
JWT_EXPIRES_IN=86400  # 24 часа